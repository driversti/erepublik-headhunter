# =============================================================================
# Headhunter — environment configuration
# =============================================================================
# Copy this file to .env and fill in the required values. Anything below the
# "Optional" headers can be left untouched for a default deployment.

# ---- eRepublik bot account (required) --------------------------------------
# The in-game account the bot logs into to read battle stats. Use a dedicated
# account if you can — it shouldn't be one you actively play with.
EREP_EMAIL=
EREP_PASSWORD=

# ---- Telegram (required) ---------------------------------------------------
# Create a bot via @BotFather, paste the token here.
BOT_TOKEN=
# Your numeric Telegram user id. The owner bypasses the registration approval
# step, sees admin commands (/users, /pending, /allvictims, etc.), and is the
# recipient of failure pages from the bot. Use @userinfobot to look up your id.
OWNER_TELEGRAM_ID=
# Public https URL where the Mini App is reachable. Telegram opens this URL
# inside its WebView, so it must be publicly resolvable AND served over HTTPS.
# See README "Mini App + reverse proxy" for the setup options. If you don't
# care about the Mini App for now, set it to a placeholder like
# https://example.com — the bot still works, only the menu button breaks.
MINIAPP_URL=

# ---- Postgres (required) ---------------------------------------------------
# Used by docker-compose to provision the bundled Postgres container, and by
# the bot to construct DATABASE_URL. If you bring your own Postgres, override
# DATABASE_URL directly and ignore DB_PASSWORD.
DB_PASSWORD=changeme

# ---- Optional: VPN sidecar -------------------------------------------------
# eRepublik occasionally Cloudflare-challenges or rate-limits hot residential
# IPs. Routing the bot through a VPN with stable European exit nodes side-
# steps that. To enable, copy docker-compose.override.example.yml to
# docker-compose.override.yml and fill in your provider creds.
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# VPN_SERVICE_PROVIDER=surfshark
# SERVER_COUNTRIES=Germany,Belgium,Austria,Netherlands

# ---- Optional: tuning ------------------------------------------------------
# Polling cadences and windows. Defaults are sensible — only override if
# you've read SPEC.md §11 and have a reason.
# POLL_CAMPAIGNS_SEC=60
# POLL_INWINDOW_SEC=30
# WINDOW_SECONDS=300
# PROBE_LEAD_SEC=300
# CANDIDATE_MIN_ELAPSED_SEC=5100

# Telegram initData replay window (seconds). Default 24h.
# MINIAPP_INITDATA_TTL_SEC=86400

# Logging.
# LOG_LEVEL=info       # trace | debug | info | warn | error | fatal | silent
# LOG_PRETTY=false     # true → human-readable logs (dev only)

# HTTP port the Mini App + REST API binds to inside the container. Almost
# nobody needs to change this — to remap externally, change the left side of
# "ports" in docker-compose.yml instead.
# HTTP_PORT=3000
