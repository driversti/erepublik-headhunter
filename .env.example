# eRepublik bot account credentials.
# Used by AuthManager during the HTTP-only login flow (SPEC §5.5).
EREP_EMAIL=
EREP_PASSWORD=

# Optional: override the default Chrome 131 User-Agent. If unset, the bundled
# default is used (see src/erep/headers.ts). Keep this in sync with current
# Chrome on Windows to avoid Cloudflare friction.
# EREP_USER_AGENT=

# Postgres connection string used by the persistence layer (migrations + repos).
DATABASE_URL=postgres://headhunter:headhunter@localhost:5432/headhunter

# Owner Telegram user ID (numeric). Bypasses approval; sees admin commands.
# Required by the Telegram bot — not used by the persistence layer.
# OWNER_TELEGRAM_ID=

# Polling cadences (defaults match SPEC §11; rarely need to override).
# POLL_CAMPAIGNS_SEC=60
# POLL_INWINDOW_SEC=30
# WINDOW_SECONDS=300
# PROBE_LEAD_SEC=300
# CANDIDATE_MIN_ELAPSED_SEC=5100
