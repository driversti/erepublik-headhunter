{
  "name": "headhunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "eRepublik air-round monitoring bot — auth + HTTP client module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest --exclude '**/*.integration.test.ts'",
    "test:integration": "node --env-file=.env ./node_modules/vitest/dist/cli.js run src/erep/__tests__/auth.integration.test.ts",
    "test:db": "vitest run 'src/db/**/*.integration.test.ts' src/erep/__tests__/postgres-session-store.integration.test.ts",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:down": "node-pg-migrate down",
    "db:migrate:create": "node-pg-migrate create -j sql",
    "demo:login": "node --env-file=.env --import tsx scripts/login-demo.ts",
    "demo:setcookie": "node --env-file=.env --import tsx scripts/set-cookie.ts",
    "demo:inspect-battle-stats": "node --env-file=.env --import tsx scripts/inspect-battle-stats.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "express": "^5.2.1",
    "grammy": "^1.42.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "zod": "^4.4.2"
  }
}
